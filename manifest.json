{
  "manifest_version": 3,
  "name": "a11y DevTools",
  "version": "2.0.0",
  "description": "Advanced accessibility testing powered by axe-core",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js",
    "type": "classic"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "a11y DevTools"
  },

  "devtools_page": "devtools/devtools.html",

  "web_accessible_resources": [
    {
      "resources": [
        "axe/axe.min.js",
        "shared/messaging.js",
        "core/scoring.js",
        "core/formatter.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
